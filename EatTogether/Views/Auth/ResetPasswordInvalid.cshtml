@{
    ViewData["Title"] = "連結無效";
    ViewData["HideNav"] = true;
    ViewData["BodyClass"] = "auth-page";
}


<div class="auth-wrapper" style="max-width:460px;" data-auth-page="reset-password-invalid">
    <div class="auth-card" style="text-align:center;">

        <!-- 警告圖示 -->
        <div class="invalid-icon">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>

        <h1 class="auth-card-title">連結無效</h1>

        <p class="auth-card-desc" style="margin-bottom:1.5rem;">
            此密碼重設連結無法使用，<br>
            可能已逾期（超過 60 分鐘）或已被使用過，<br>
            請重新申請密碼重設連結。
        </p>

        <button class="btn-auth-primary"
                onclick="window.location.href='/Auth/ForgotPassword'"
                style="max-width:260px;margin:0 auto;">
            <i class="fa-solid fa-rotate me-2"></i>返回登入頁重新申請
        </button>

    </div>
</div>

@section Styles
{
        <link rel="stylesheet" href="~/css/views/auth.css">
        <style>
            .invalid-icon {
                width: 80px;
                height: 80px;
                background: linear-gradient(135deg, #e8403a 0%, #c0322c 100%);
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 2.2rem;
                color: white;
                margin-bottom: 1rem;
                box-shadow: 0 8px 24px rgba(232, 64, 58, 0.35);
                animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
            }

            @@keyframes popIn {
                from {
                    opacity: 0;
                    transform: scale(0.5);
                }

                to {
                    opacity: 1;
                    transform: scale(1);
                }
            }
        </style>
}

@section Scripts
{
        <script src="~/js/views/auth.js"></script>
}
