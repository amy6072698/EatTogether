@{
    ViewData["Title"] = "重設密碼";
    ViewData["HideNav"] = true;
    ViewData["BodyClass"] = "auth-page";
}


<div class="auth-wrapper" style="max-width:460px;" data-auth-page="reset-password">
    <div class="auth-card">

        <!-- 標頭 -->
        <div class="auth-card-header">
            <div class="auth-card-icon orange">
                <i class="fa-solid fa-unlock-keyhole"></i>
            </div>
            <h1 class="auth-card-title">重設密碼</h1>
            <p class="auth-card-desc">請設定您的新密碼</p>
        </div>

        <!-- 警示訊息 -->
        <div class="auth-alert danger" id="auth-alert" role="alert">
            <i class="fa-solid fa-circle-exclamation"></i>
            <span class="alert-msg"></span>
        </div>

        <!-- 表單 -->
        <form id="reset-password-form" novalidate autocomplete="off">

            <!--
                後端 Razor 注入 Token（隱藏欄位）
                <input type="hidden" id="reset-token" name="token" value="@Model.Token" />
            -->
            @* <input type="hidden" id="reset-token" name="token" value="DEMO_TOKEN" /> *@

            <input type="hidden" id="reset-token" name="token" value="@ViewBag.Token" />

            <!-- 新密碼 -->
            <div class="auth-form-group">
                <label class="auth-label" for="new-password">新密碼</label>
                <div class="auth-input-wrap">
                    <input type="password"
                            class="auth-input"
                            id="new-password"
                            name="newPassword"
                            placeholder="請輸入新密碼"
                            autocomplete="new-password"
                            maxlength="100" />
                    <button type="button" class="toggle-password" data-target="new-password" aria-label="切換密碼顯示">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                </div>
                <div class="auth-input-error" id="new-password-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span></span>
                </div>
            </div>

            <!-- 密碼規則 -->
            <div class="password-rules">
                <div class="password-rules-title">密碼規則</div>
                <div class="password-rule" data-rule="length">
                    <i class="fa-regular fa-circle"></i>
                    至少 6 個字元
                </div>
                <div class="password-rule" data-rule="alpha">
                    <i class="fa-regular fa-circle"></i>
                    包含英文字母（a-z / A-Z）
                </div>
                <div class="password-rule" data-rule="num">
                    <i class="fa-regular fa-circle"></i>
                    包含數字（0-9）
                </div>
            </div>

            <!-- 確認密碼 -->
            <div class="auth-form-group">
                <label class="auth-label" for="confirm-password">確認密碼</label>
                <div class="auth-input-wrap">
                    <input type="password"
                            class="auth-input"
                            id="confirm-password"
                            name="confirmPassword"
                            placeholder="請再次輸入新密碼"
                            autocomplete="new-password"
                            maxlength="100" />
                    <button type="button" class="toggle-password" data-target="confirm-password" aria-label="切換密碼顯示">
                        <i class="fa-solid fa-eye"></i>
                    </button>
                </div>
                <div class="auth-input-error" id="confirm-password-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span></span>
                </div>
            </div>

            <button type="submit" class="btn-auth-primary" id="reset-submit-btn">
                確定重設
            </button>

        </form>

    </div>
</div>

@section Styles
{
    <link rel="stylesheet" href="~/css/views/auth.css">
}

@section Scripts
{
    <script src="~/js/views/auth.js"></script>
}