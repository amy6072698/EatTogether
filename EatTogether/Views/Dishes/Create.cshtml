@model EatTogether.Models.ViewModels.DishViewModel
@{
    ViewData["Title"] = "新增餐點";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">新增餐點</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">餐點管理</a></li>
        <li class="breadcrumb-item active">新增餐點</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-plus me-1"></i>新增餐點
        </div>
        <div class="card-body">
            <div id="alertBox"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">餐點名稱 <span class="text-danger">*</span></label>
                    <input type="text" id="DishName" class="form-control" placeholder="請輸入餐點名稱" />
                    <div class="text-danger small" id="DishName-error"></div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">分類 <span class="text-danger">*</span></label>
                    <select id="CategoryId" class="form-select">
                        <option value="">請選擇分類</option>
                        @foreach (var option in Model.CategoryOptions)
                        {
                            <option value="@option.Value">@option.Text</option>
                        }
                    </select>
                    <div class="text-danger small" id="CategoryId-error"></div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">價格 <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" id="Price" class="form-control" placeholder="0" min="0" />
                    </div>
                    <div class="text-danger small" id="Price-error"></div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">圖片網址</label>
                    <input type="text" id="ImageUrl" class="form-control" placeholder="請輸入圖片網址（選填）" />
                </div>

                <div class="col-12 mb-3">
                    <label class="form-label">描述</label>
                    <textarea id="Description" class="form-control" rows="3"
                              placeholder="請輸入餐點描述（選填）"></textarea>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">限定供應</label>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="IsLimited"
                               onchange="toggleDateRange()" />
                        <label class="form-check-label" for="IsLimited">限定供應</label>
                    </div>
                    <div id="dateRange" class="d-none">
                        <div class="d-flex gap-2">
                            <input type="date" id="StartDate" class="form-control" />
                            <span class="align-self-center">~</span>
                            <input type="date" id="EndDate" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">其他設定</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="IsTakeOut" checked />
                        <label class="form-check-label" for="IsTakeOut">可外帶</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="IsActive" checked />
                        <label class="form-check-label" for="IsActive">啟用</label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary" onclick="submitCreate()">
                    <i class="fas fa-save me-1"></i>儲存
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>返回列表
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleDateRange() {
            const isLimited = document.getElementById("IsLimited").checked;
            document.getElementById("dateRange").classList.toggle("d-none", !isLimited);
        }

        async function submitCreate() {
            clearErrors();

            const isLimited = document.getElementById("IsLimited").checked;

            const data = {
                DishName:    document.getElementById("DishName").value,
                CategoryId:  parseInt(document.getElementById("CategoryId").value) || 0,
                Price:       parseFloat(document.getElementById("Price").value) || 0,
                Description: document.getElementById("Description").value || null,
                ImageUrl:    document.getElementById("ImageUrl").value || null,
                IsTakeOut:   document.getElementById("IsTakeOut").checked,
                IsLimited:   isLimited,
                StartDate:   isLimited ? document.getElementById("StartDate").value || null : null,
                EndDate:     isLimited ? document.getElementById("EndDate").value || null : null,
                IsActive:    document.getElementById("IsActive").checked
            };

            const res = await fetch("/Dishes/Create", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                window.location.href = "/Dishes";
            } else if (res.status === 400) {
                const errors = await res.json();
                showErrors(errors);
            } else {
                showAlert("danger", "儲存失敗，請稍後再試");
            }
        }

        function clearErrors() {
            document.querySelectorAll(".text-danger.small").forEach(el => el.textContent = "");
        }

        function showErrors(errors) {
            for (const [key, messages] of Object.entries(errors)) {
                const el = document.getElementById(`${key}-error`);
                if (el) el.textContent = messages.join(", ");
            }
        }

        function showAlert(type, message) {
            document.getElementById("alertBox").innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;
        }
    </script>
}