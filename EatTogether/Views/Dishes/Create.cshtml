@model EatTogether.Models.ViewModels.DishViewModel
@{
    ViewData["Title"] = "新增餐點";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">新增餐點</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">餐點管理</a></li>
        <li class="breadcrumb-item active">新增餐點</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-plus me-1"></i>新增餐點
        </div>
        <div class="card-body">

            <form method="post" enctype="multipart/form-data" asp-action="Create" id="createForm">
                @Html.AntiForgeryToken()
                <!-- 裁切後的圖片 Base64 -->
                <input type="hidden" id="croppedImageData" name="CroppedImageData" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">餐點名稱 <span class="text-danger">*</span></label>
                        <input asp-for="DishName" class="form-control" placeholder="請輸入餐點名稱" />
                        <span asp-validation-for="DishName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">分類 <span class="text-danger">*</span></label>
                        <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                            <option value="">請選擇分類</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">價格 <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control" placeholder="0" min="0" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <!-- 圖片上傳 -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">圖片上傳</label>
                        <input type="file" id="imageInput" class="form-control" accept="image/*"
                               onchange="openCropper(this)" />
                        <!-- 裁切後預覽，預設隱藏 -->
                        <div id="previewBox" class="mt-2" style="display:none">
                            <img id="previewImg" src=""
                                 style="width:100%; max-height:200px; object-fit:cover; border-radius:8px;" />
                            <button type="button" class="btn btn-sm btn-outline-secondary mt-1"
                                    onclick="openCropperAgain()">
                                <i class="fas fa-crop me-1"></i>重新裁切
                            </button>
                        </div>
                    </div>

                    <div class="col-12 mb-3">
                        <label class="form-label">描述</label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="請輸入餐點描述（選填）"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">限定供應</label>
                        <div class="form-check mb-2">
                            <input asp-for="IsLimited" class="form-check-input"
                                   onchange="toggleDateRange()" />
                            <label class="form-check-label" asp-for="IsLimited">限定供應</label>
                        </div>
                        <div id="dateRange" class="d-none">
                            <div class="d-flex gap-2">
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span class="align-self-center">~</span>
                                <input asp-for="EndDate" type="date" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">其他設定</label>
                        <div class="form-check">
                            <input asp-for="IsTakeOut" class="form-check-input" />
                            <label class="form-check-label" asp-for="IsTakeOut">可外帶</label>
                        </div>
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label class="form-check-label" asp-for="IsActive">啟用</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>儲存
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>返回列表
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Cropper Modal -->
<div class="modal fade" id="cropperModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">裁切圖片</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div style="max-height:500px; overflow:hidden;">
                    <img id="cropperImage" src="" style="max-width:100%;" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="confirmCrop()">
                    <i class="fas fa-check me-1"></i>確認裁切
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <script>
        let cropper = null;
        let originalFile = null;

        function toggleDateRange() {
            const isLimited = document.getElementById("IsLimited").checked;
            document.getElementById("dateRange").classList.toggle("d-none", !isLimited);
        }

        function openCropper(input) {
            if (!input.files || !input.files[0]) return;
            originalFile = input.files[0];

            const reader = new FileReader();
            reader.onload = e => {
                const img = document.getElementById("cropperImage");
                img.src = e.target.result;

                const modal = new bootstrap.Modal(document.getElementById("cropperModal"));
                modal.show();

                document.getElementById("cropperModal").addEventListener("shown.bs.modal", () => {
                    if (cropper) cropper.destroy();
                    cropper = new Cropper(img, {
                        aspectRatio: 4 / 3,
                        viewMode: 1,
                        movable: true,
                        zoomable: true,
                        rotatable: false
                    });
                }, { once: true });
            };
            reader.readAsDataURL(originalFile);
        }

        function openCropperAgain() {
            if (!originalFile) return;
            const input = document.getElementById("imageInput");
            openCropper(input);
        }

        function confirmCrop() {
            if (!cropper) return;

            const canvas = cropper.getCroppedCanvas({ width: 800, height: 600 });
            const base64  = canvas.toDataURL("image/jpeg", 0.9);

            // 存入 hidden input
            document.getElementById("croppedImageData").value = base64;

            // 顯示預覽
            document.getElementById("previewImg").src = base64;
            document.getElementById("previewBox").style.display = "";

            // 關閉 Modal
            bootstrap.Modal.getInstance(document.getElementById("cropperModal")).hide();
            cropper.destroy();
            cropper = null;
        }
    </script>
}
