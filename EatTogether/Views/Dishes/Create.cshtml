@model EatTogether.Models.ViewModels.DishViewModel
@{
    ViewData["Title"] = "新增餐點";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">新增餐點</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">餐點管理</a></li>
        <li class="breadcrumb-item active">新增餐點</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-plus me-1"></i>新增餐點基本資料</span>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>返回列表
            </a>
        </div>
        <div class="card-body">
            <form method="post" enctype="multipart/form-data" asp-action="Create" id="createForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="croppedImageData" name="CroppedImageData" />
                <input type="hidden" asp-for="DisplayOrder" />

                <div class="row">
                    <!-- 左側資料區 -->
                    <div class="col-lg-8">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">餐點名稱 <span class="text-danger">*</span></label>
                                <input asp-for="DishName" class="form-control" placeholder="請輸入餐點名稱" />
                                <span asp-validation-for="DishName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">所屬分類 <span class="text-danger">*</span></label>
                                <select asp-for="CategoryId" asp-items="Model.CategoryOptions" class="form-select">
                                    <option value="">請選擇分類</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">定價 <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="Price" class="form-control" placeholder="0" min="0" step="1" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">餐點描述</label>
                                <textarea asp-for="Description" class="form-control" rows="4"
                                          placeholder="請輸入餐點描述（選填）"></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12 border-top pt-3">
                                <label class="form-label fw-bold">供應與狀態設定</label>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-check form-switch mb-2">
                                            <input asp-for="IsLimited" class="form-check-input" type="checkbox" role="switch" onchange="toggleDateRange()">
                                            <label class="form-check-label fw-bold" asp-for="IsLimited">限定供應期間</label>
                                        </div>
                                        <div id="dateRange" class="mt-2 @(Model.IsLimited ? "" : "d-none")">
                                            <div class="input-group input-group-sm">
                                                <input asp-for="StartDate" type="date" class="form-control" />
                                                <span class="input-group-text">至</span>
                                                <input asp-for="EndDate" type="date" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-check mb-2">
                                            <input asp-for="IsTakeOut" class="form-check-input" />
                                            <label class="form-check-label fw-bold" asp-for="IsTakeOut">可外帶</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-check mb-2">
                                            <input asp-for="IsActive" class="form-check-input" checked />
                                            <label class="form-check-label fw-bold" asp-for="IsActive">立即啟用</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 右側圖片區 -->
                    <div class="col-lg-4 border-start">
                        <div class="ps-lg-3">
                            <label class="form-label fw-bold">餐點圖片</label>
                            
                            <div id="imagePlaceholder" class="border rounded bg-light d-flex flex-column align-items-center justify-content-center mb-3" 
                                 style="aspect-ratio: 4/3; cursor: pointer;" onclick="document.getElementById('imageInput').click()">
                                <i class="fas fa-utensils fa-3x text-secondary mb-2"></i>
                                <span class="text-secondary">點擊或拖曳圖片至此</span>
                                <small class="text-muted mt-1">建議比例 4:3</small>
                            </div>

                            <div id="previewBox" class="mb-3" style="display:none">
                                <div class="position-relative">
                                    <img id="previewImg" src="" class="img-fluid rounded border" style="width:100%; aspect-ratio: 4/3; object-fit: cover;" />
                                    <div class="position-absolute bottom-0 end-0 p-2">
                                        <button type="button" class="btn btn-sm btn-dark opacity-75" onclick="openCropperAgain()">
                                            <i class="fas fa-crop me-1"></i>重新裁切
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <input type="file" id="imageInput" class="form-control d-none" accept="image/*"
                                   onchange="handleFileSelect(this)" />
                            
                            <div class="d-grid mt-3">
                                <button type="button" class="btn btn-outline-primary" onclick="document.getElementById('imageInput').click()">
                                    <i class="fas fa-upload me-1"></i>選擇圖片
                                </button>
                            </div>
                            
                            <div class="mt-4 p-3 bg-light rounded border border-info">
                                <h6 class="text-info mb-2"><i class="fas fa-info-circle me-1"></i>上傳說明</h6>
                                <ul class="small text-muted mb-0 ps-3">
                                    <li>選擇圖片後將開啟裁切視窗</li>
                                    <li>請調整至最佳範圍後按下「確認裁切」</li>
                                    <li>最後按下下方的「儲存餐點」完成新增</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-end gap-2 mb-3">
                    <button type="button" class="btn btn-light px-4" onclick="location.href='@Url.Action("Index")'">取消</button>
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="fas fa-save me-2"></i>儲存餐點
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Cropper Modal -->
<div class="modal fade" id="cropperModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-crop me-2"></i>裁切圖片</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="img-container" style="background-color: #f7f7f7; height: 500px; width: 100%;">
                    <img id="cropperImage" src="" style="max-width: 100%;">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary px-4" onclick="confirmCrop()">
                    <i class="fas fa-check me-2"></i>確認裁切
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
    <style>
        #imagePlaceholder:hover {
            border-color: #0d6efd !important;
            background-color: #f8f9fa !important;
        }
        #imagePlaceholder:hover i {
            color: #0d6efd !important;
        }
        .img-container img {
            display: block;
            max-width: 100%;
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <script>
        let cropper = null;
        let originalFile = null;

        function toggleDateRange() {
            const isLimited = document.getElementById("IsLimited").checked;
            const dateRange = document.getElementById("dateRange");
            if(dateRange) {
                dateRange.classList.toggle("d-none", !isLimited);
            }
        }

        function handleFileSelect(input) {
            if (!input.files || !input.files[0]) return;
            openCropper(input.files[0]);
        }

        function openCropper(file) {
            originalFile = file;

            const reader = new FileReader();
            reader.onload = e => {
                const img = document.getElementById("cropperImage");
                img.src = e.target.result;

                const modalElement = document.getElementById("cropperModal");
                const modal = new bootstrap.Modal(modalElement);
                modal.show();

                modalElement.addEventListener("shown.bs.modal", () => {
                    if (cropper) cropper.destroy();
                    cropper = new Cropper(img, {
                        aspectRatio: 4 / 3,
                        viewMode: 1,
                        movable: true,
                        zoomable: true,
                        rotatable: false,
                        autoCropArea: 1
                    });
                }, { once: true });
            };
            reader.readAsDataURL(originalFile);
        }

        function openCropperAgain() {
            if (!originalFile) {
                 document.getElementById('imageInput').click();
                 return;
            }
            openCropper(originalFile);
        }

        function confirmCrop() {
            if (!cropper) return;

            const canvas = cropper.getCroppedCanvas({ width: 800, height: 600 });
            const base64  = canvas.toDataURL("image/jpeg", 0.9);

            document.getElementById("croppedImageData").value = base64;
            document.getElementById("previewImg").src = base64;
            document.getElementById("previewBox").style.display = "block";
            document.getElementById("imagePlaceholder").style.display = "none";

            const modalElement = document.getElementById("cropperModal");
            const modal = bootstrap.Modal.getInstance(modalElement);
            modal.hide();
            
            cropper.destroy();
            cropper = null;
        }

        // 支援拖曳上傳
        const placeholder = document.getElementById('imagePlaceholder');
        if(placeholder) {
            placeholder.addEventListener('dragover', (e) => {
                e.preventDefault();
                placeholder.classList.add('bg-secondary', 'bg-opacity-10', 'border-primary');
            });
            placeholder.addEventListener('dragleave', () => {
                placeholder.classList.remove('bg-secondary', 'bg-opacity-10', 'border-primary');
            });
            placeholder.addEventListener('drop', (e) => {
                e.preventDefault();
                placeholder.classList.remove('bg-secondary', 'bg-opacity-10', 'border-primary');
                if (e.dataTransfer.files && e.dataTransfer.files[0]) {
                    openCropper(e.dataTransfer.files[0]);
                }
            });
        }
    </script>
}
