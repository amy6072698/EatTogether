@model IEnumerable<EatTogether.Models.DTOs.MemberCouponDto>
@{
    ViewData["Title"] = "會員領券紀錄";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">會員領券紀錄</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">優惠券管理</a></li>
        <li class="breadcrumb-item active">領券紀錄</li>
    </ol>

    <!-- 統計卡片 -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small">領券總筆數</div>
                        <div class="fs-4 fw-bold">@Model.Count()</div>
                    </div>
                    <i class="fas fa-ticket-alt fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-success text-white mb-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small">未使用</div>
                        <div class="fs-4 fw-bold">@Model.Count(m => !m.IsUsed)</div>
                    </div>
                    <i class="fas fa-check-circle fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-danger text-white mb-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small">已使用</div>
                        <div class="fs-4 fw-bold">@Model.Count(m => m.IsUsed)</div>
                    </div>
                    <i class="fas fa-times-circle fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-warning text-dark mb-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small">持券會員數</div>
                        <div class="fs-4 fw-bold">@Model.Select(m => m.MemberId).Distinct().Count()</div>
                    </div>
                    <i class="fas fa-users fa-2x opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div><i class="fas fa-list me-1"></i>領券紀錄</div>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-1"></i>返回優惠券列表
            </a>
        </div>
        <div class="card-body">
            <table id="memberCouponTable" class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>會員姓名</th>
                        <th>會員帳號</th>
                        <th>優惠券名稱</th>
                        <th>折扣碼</th>
                        <th>折扣說明</th>
                        <th>到期日</th>
                        <th>使用狀態</th>
                        <th>使用時間</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @foreach (var mc in Model)
                    {
                        var rowClass = mc.IsUsed ? "" : mc.IsExpired ? "table-warning" : "";
                        <tr class="@rowClass">
                            <td class="text-muted small">@(i++)</td>
                            <td class="fw-semibold">@mc.MemberName</td>
                            <td class="small text-muted">@mc.MemberAccount</td>
                            <td>@mc.CouponName</td>
                            <td>
                                <code class="@(mc.IsExpired ? "text-danger" : "")">@mc.Code</code>
                            </td>
                            <td class="small">@mc.DiscountDescription</td>
                            <td class="small">
                                @if (!mc.EndDate.HasValue)
                                {
                                    <span class="text-success">永久有效</span>
                                }
                                else if (mc.IsExpired)
                                {
                                    <span class="text-danger">
                                        @mc.EndDate?.ToString("yyyy/M/d")（已過期）
                                    </span>
                                }
                                else
                                {
                                    <span>@mc.EndDate?.ToString("yyyy/M/d")</span>
                                }
                            </td>
                            <td>
                                <span class="badge @mc.StatusBadgeClass">@mc.StatusText</span>
                            </td>
                            <td class="small text-muted">
                                @(mc.UsedDate.HasValue? mc.UsedDate.Value.ToString("yyyy/M/d HH:mm") : "—")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js"></script>
    <script>
        const dataTable = new simpleDatatables.DataTable("#memberCouponTable", {
            labels: {
                placeholder: "搜尋...",
                searchTitle: "搜尋",
                perPage: "每頁顯示",
                noRows: "無資料",
                info: "顯示第 {start} 至 {end} 筆，共 {rows} 筆",
                loading: "載入中...",
                infoFiltered: "（從 {rowsTotal} 筆中篩選）",
                noResults: "無符合資料"
            }
        });
    </script>
}
