@model EatTogether.Models.ViewModels.CouponCreateViewModel
@{
    ViewData["Title"] = "新增優惠券";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">新增優惠券</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">優惠券管理</a></li>
        <li class="breadcrumb-item active">新增優惠券</li>
    </ol>

    <div class="card mb-4" style="max-width: 720px;">
        <div class="card-header">
            <i class="fas fa-plus me-1"></i>新增優惠券
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- 基本資訊 -->
                <h6 class="text-muted fw-bold text-uppercase small mb-3 border-bottom pb-2">基本資訊</h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">
                            活動名稱 <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               placeholder="如：2026 中秋聚餐優惠" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Code" class="form-label">
                            折扣碼 <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Code" class="form-control text-uppercase"
                               placeholder="英數大寫，如 MOON2026"
                               style="font-family: monospace; letter-spacing: 2px;"
                               oninput="this.value = this.value.toUpperCase()" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                        <div class="form-text">折扣碼不可重複，只允許英文大寫與數字</div>
                    </div>
                </div>

                <!-- 折扣設定 -->
                <h6 class="text-muted fw-bold text-uppercase small mb-3 border-bottom pb-2 mt-4">折扣設定</h6>
                <div class="mb-3">
                    <label class="form-label">折扣類型 <span class="text-danger">*</span></label>
                    <div class="d-flex gap-4">
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   asp-for="DiscountType" value="0"
                                   id="typeAmount" onchange="updateHint(0)">
                            <label class="form-check-label" for="typeAmount">折金額（$）</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   asp-for="DiscountType" value="1"
                                   id="typePercent" onchange="updateHint(1)">
                            <label class="form-check-label" for="typePercent">打折（%）</label>
                        </div>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="DiscountValue" class="form-label">
                            折扣數值 <span class="text-danger">*</span>
                        </label>
                        <input asp-for="DiscountValue" type="number" min="1"
                               class="form-control" placeholder="如 100 或 10" />
                        <span asp-validation-for="DiscountValue" class="text-danger small"></span>
                        <div class="form-text" id="discountHint">
                            折金額：輸入金額 ／ 打折：輸入折扣百分比（10 = 九折）
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MinSpend" class="form-label">最低消費門檻</label>
                        <input asp-for="MinSpend" type="number" min="0"
                               class="form-control" placeholder="0 代表無門檻" />
                        <span asp-validation-for="MinSpend" class="text-danger small"></span>
                    </div>
                </div>

                <!-- 有效期間與數量 -->
                <h6 class="text-muted fw-bold text-uppercase small mb-3 border-bottom pb-2 mt-4">有效期間與數量</h6>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="StartDate" class="form-label">
                            活動開始日 <span class="text-danger">*</span>
                        </label>
                        <input asp-for="StartDate" type="datetime-local" class="form-control" />
                        <span asp-validation-for="StartDate" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EndDate" class="form-label">活動結束日</label>
                        <input asp-for="EndDate" type="datetime-local" class="form-control" />
                        <div class="form-text">留空代表永久有效</div>
                    </div>
                </div>
                <div class="mb-4">
                    <label asp-for="LimitCount" class="form-label">限量張數</label>
                    <input asp-for="LimitCount" type="number" min="1"
                           class="form-control" placeholder="留空代表無限量"
                           style="max-width: 240px;" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-ticket-alt me-1"></i>建立優惠券
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>返回列表
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function updateHint(type) {
            document.getElementById('discountHint').textContent = type === 0
                ? '輸入折抵金額，如 100 代表折 $100'
                : '輸入折扣百分比，如 10 代表打九折（扣 10%）';
        }
    </script>
}
