@model EatTogether.Models.ViewModels.CategoryViewModel
@{
    ViewData["Title"] = "新增分類";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">新增分類</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">分類管理</a></li>
        <li class="breadcrumb-item active">新增分類</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-plus me-1"></i>新增分類
        </div>
        <div class="card-body">
            <div id="alertBox"></div>

            <div class="mb-3">
                <label class="form-label">分類名稱 <span class="text-danger">*</span></label>
                <input type="text" id="CategoryName" class="form-control" placeholder="請輸入分類名稱" />
                <div class="text-danger small" id="CategoryName-error"></div>
            </div>

            <div class="mb-3">
                <label class="form-label">上層分類</label>
                <select id="ParentCategoryId" class="form-select">
                    @foreach (var option in Model.ParentCategoryOptions)
                    {
                        <option value="@option.Value">@option.Text</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">顯示順序 <span class="text-danger">*</span></label>
                <input type="number" id="DisplayOrder" class="form-control" value="1" min="1" max="999" />
                <div class="text-danger small" id="DisplayOrder-error"></div>
            </div>

            <div class="mb-3">
                <label class="form-label">圖片網址</label>
                <input type="text" id="ImageUrl" class="form-control" placeholder="請輸入圖片網址（選填）" />
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="IsActive" checked />
                    <label class="form-check-label" for="IsActive">啟用</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary" onclick="submitCreate()">
                    <i class="fas fa-save me-1"></i>儲存
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-1"></i>返回列表
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function submitCreate() {
            clearErrors();

            const data = {
                CategoryName:     document.getElementById("CategoryName").value,
                ParentCategoryId: document.getElementById("ParentCategoryId").value || null,
                DisplayOrder:     parseInt(document.getElementById("DisplayOrder").value),
                ImageUrl:         document.getElementById("ImageUrl").value || null,
                IsActive:         document.getElementById("IsActive").checked
            };

            const res = await fetch("/Categories/Create", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                window.location.href = "/Categories";
            } else if (res.status === 400) {
                const errors = await res.json();
                showErrors(errors);
            } else {
                showAlert("danger", "儲存失敗，請稍後再試");
            }
        }

        function clearErrors() {
            document.querySelectorAll(".text-danger.small").forEach(el => el.textContent = "");
        }

        function showErrors(errors) {
            for (const [key, messages] of Object.entries(errors)) {
                const el = document.getElementById(`${key}-error`);
                if (el) el.textContent = messages.join(", ");
            }
        }

        function showAlert(type, message) {
            document.getElementById("alertBox").innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;
        }
    </script>
}