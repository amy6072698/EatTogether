@model EatTogether.Models.ViewModels.TableCreateViewModel
@{
    ViewData["Title"] = "新增桌位";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">新增桌位</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">桌位管理</a></li>
        <li class="breadcrumb-item active">新增桌位</li>
    </ol>

    <div class="card mb-4" style="max-width: 560px;">
        <div class="card-header">
            <i class="fas fa-plus me-1"></i>新增桌位
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="TableName" class="form-label">
                        桌位名稱 <span class="text-danger">*</span>
                    </label>
                    <input asp-for="TableName" class="form-control"
                           placeholder="如 A5、OUT4、VIP3" />
                    <span asp-validation-for="TableName" class="text-danger small"></span>
                    <div class="form-text">桌位名稱必須唯一，重複時系統會提示錯誤</div>
                </div>

                <div class="mb-3">
                    <label asp-for="SeatCount" class="form-label">
                        座位數 <span class="text-danger">*</span>
                    </label>
                    <input asp-for="SeatCount" type="number" min="1"
                           class="form-control" />
                    <span asp-validation-for="SeatCount" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-plus me-1"></i>新增桌位
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>返回列表
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
