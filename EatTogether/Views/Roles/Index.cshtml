<!-- ============================================================
     新增角色 Modal
     ============================================================ -->
<div class="modal fade" id="modal-create-role" tabindex="-1" aria-labelledby="modal-create-role-label" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modal-create-role-label">
                    <i class="fa-solid fa-plus-circle me-2 text-primary"></i>新增角色
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>
            <div class="modal-body roles-index">

                <!-- 基本資料 -->
                <div class="mb-4">
                    <h6 class="section-title">基本資料</h6>
                    <div class="mb-3">
                        <label class="form-label form-label-sm required-label" for="create-role-name">角色名稱</label>
                        <input type="text" class="form-control form-control-sm" id="create-role-name" maxlength="50" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label form-label-sm" for="create-role-desc">角色描述</label>
                        <textarea class="form-control form-control-sm" id="create-role-desc" rows="2" maxlength="200"></textarea>
                    </div>
                </div>

                <!-- 擁有的權限 -->
                <div class="mb-4">
                    <h6 class="section-title">擁有的權限</h6>
                    <p class="text-muted small mb-2">
                        <i class="fa-solid fa-circle-info me-1"></i>
                        員工管理與報表管理是店長才有的權限，無法指派給其他角色。
                    </p>
                    <div class="perm-card-grid" id="create-perm-grid">
                        <div class="row g-2">
                            <!-- 員工管理（disabled - IsOwnerOnly） -->
                            <div class="col-md-6">
                                <div class="perm-card owner-only">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="create-perm-Staff_Manage"
                                               value="Staff_Manage" disabled />
                                        <label class="form-check-label" for="create-perm-Staff_Manage">
                                            <span class="perm-card-name">員工管理</span>
                                            <span class="perm-card-desc">員工帳號的新增、修改、停用及角色權限指派</span>
                                            <span class="owner-only-tag">僅限店長</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <!-- 員工查看 -->
                            <div class="col-md-6">
                                <div class="perm-card">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="create-perm-Staff_View"
                                               name="functions" value="Staff_View" />
                                        <label class="form-check-label" for="create-perm-Staff_View">
                                            <span class="perm-card-name">員工查看</span>
                                            <span class="perm-card-desc">查看員工列表及基本資料，不含修改</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <!-- 會員管理 -->
                            <div class="col-md-6">
                                <div class="perm-card">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="create-perm-Member_Manage"
                                               name="functions" value="Member_Manage" />
                                        <label class="form-check-label" for="create-perm-Member_Manage">
                                            <span class="perm-card-name">會員管理</span>
                                            <span class="perm-card-desc">查看會員資料、設定黑名單</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <!-- 訂單管理 -->
                            <div class="col-md-6">
                                <div class="perm-card">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="create-perm-Order_Manage"
                                               name="functions" value="Order_Manage" />
                                        <label class="form-check-label" for="create-perm-Order_Manage">
                                            <span class="perm-card-name">訂單管理（含結帳）</span>
                                            <span class="perm-card-desc">修改、取消訂單及執行結帳，涉及金流操作</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <!-- 更新訂單狀態 -->
                            <div class="col-md-6">
                                <div class="perm-card">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" id="create-perm-Order_Update"
                                               name="functions" value="Order_Update" />
                                        <label class="form-check-label" for="create-perm-Order_Update">
                                            <span class="perm-card-name">更新訂單狀態</span>
                                            <span class="perm-card-desc">查看訂單清單並更新訂單狀態，不含結帳</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                            <!-- 菜單管理 -->
                            <div class="col-md-6">
                                <div class="perm-card">
