@model EatTogether.Models.ViewModels.PaymentIndexViewModel

@{
    ViewData["Title"] = "結帳";
    var takeOrders = Model.TakeoutOrders;  // ← 宣告在這裡
}

<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet" />

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'Noto Sans TC', sans-serif;
        background: #f0f2f5;
    }

    .layout {
        display: grid;
        grid-template-columns: 800px 1fr;
        height: 100vh;
        overflow: hidden;
    }

    /* ── 左側 ── */
    .left-panel {
        background: #fff;
        border-right: 1px solid #e8e8e8;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .left-header {
        padding: 20px;
        border-bottom: 1px solid #f0f0f0;
    }

    .left-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 12px;
    }

    .tab-wrap {
        display: flex;
        gap: 8px;
    }

    .tab-btn {
        flex: 1;
        padding: 8px;
        border: 2px solid #ddd;
        border-radius: 10px;
        background: #fff;
        font-family: inherit;
        font-size: 0.88rem;
        font-weight: 500;
        color: #888;
        cursor: pointer;
        transition: all 0.15s;
        text-align: center;
    }

        .tab-btn.active {
            border-color: #c0392b;
            background: #fff5f5;
            color: #c0392b;
            font-weight: 700;
        }

    /* 桌號格子 */
    .table-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
        padding: 16px;
        overflow: hidden; /* ← 改成 hidden */
        flex: 1;
        align-content: start; /* ← 格子靠上對齊，不會被撐開 */
    }

    .table-btn {
        /* aspect-ratio: 1; */
        height: 90px; /* ← 改成固定高度 */
        border-radius: 12px;
        border: 2px solid #e8e8e8;
        background: #fafafa;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: 700;
        color: #aaa;
        transition: all 0.15s;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 4px;
        cursor: default;
    }

        .table-btn.has-order {
            border-color: #2c3e50;
            background: #fff;
            color: #1a1a1a;
            cursor: pointer;
        }

            .table-btn.has-order:hover {
                border-color: #c0392b;
                background: #fff5f5;
            }

            .table-btn.has-order.unserved {
                border-color: #e67e22;
                background: #fef9f0;
            }

        .table-btn.active-selected {
            border-color: #c0392b !important;
            background: #fff5f5 !important;
            box-shadow: 0 0 0 3px rgba(192,57,43,0.15);
        }

    .table-icon {
        font-size: 1.4rem;
    }

    .table-name {
        font-size: 0.78rem;
    }

    .table-amount {
        font-size: 0.75rem;
        color: #c0392b;
        font-weight: 700;
    }

    /* 外帶清單 */
    .takeout-list {
        padding: 12px 16px;
        overflow-y: auto;
        flex: 1;
        display: none;
    }

    .takeout-item {
        padding: 12px 14px;
        border-radius: 12px;
        border: 2px solid #e8e8e8;
        background: #fff;
        margin-bottom: 10px;
        cursor: pointer;
        transition: all 0.15s;
    }

        .takeout-item:hover {
            border-color: #c0392b;
        }

        .takeout-item.active-selected {
            border-color: #c0392b;
            background: #fff5f5;
            box-shadow: 0 0 0 3px rgba(192,57,43,0.15);
        }

        .takeout-item.unserved {
            border-color: #e67e22;
            background: #fef9f0;
        }

    .takeout-number {
        font-weight: 700;
        font-size: 0.95rem;
        color: #1a1a1a;
    }

    .takeout-meta {
        font-size: 0.8rem;
        color: #888;
        margin-top: 3px;
    }

    .takeout-amount {
        font-size: 0.88rem;
        color: #c0392b;
        font-weight: 700;
        margin-top: 4px;
    }

    /* ── 右側 ── */
    .right-panel {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: #f8f9fa;
    }

    .right-header {
        padding: 20px 24px;
        background: #fff;
        border-bottom: 1px solid #e8e8e8;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .right-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1a1a1a;
    }

    .right-subtitle {
        font-size: 0.85rem;
        color: #888;
        margin-top: 2px;
    }

    .unserved-warning {
        margin: 16px 24px 0;
        padding: 14px 18px;
        background: #fff8e1;
        border-left: 4px solid #f39c12;
        border-radius: 0 10px 10px 0;
        display: none;
    }

        .unserved-warning p {
            font-size: 0.92rem;
            color: #7d6608;
            font-weight: 500;
            margin-bottom: 10px;
        }

    .warning-btns {
        display: flex;
        gap: 10px;
    }

    .btn-yes {
        padding: 7px 20px;
        background: #e67e22;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 700;
        font-size: 0.88rem;
        cursor: pointer;
        transition: background 0.2s;
    }

        .btn-yes:hover {
            background: #d35400;
        }

    .btn-no {
        padding: 7px 20px;
        background: #fff;
        color: #555;
        border: 2px solid #ddd;
        border-radius: 8px;
        font-family: inherit;
        font-weight: 700;
        font-size: 0.88rem;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-no:hover {
            border-color: #aaa;
        }

    .detail-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 16px 24px;
    }

    .detail-table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }

        .detail-table th {
            padding: 12px 16px;
            background: #f8f9fa;
            font-size: 0.82rem;
            color: #888;
            text-align: left;
            font-weight: 700;
            letter-spacing: 0.05em;
            border-bottom: 1px solid #f0f0f0;
        }

            .detail-table th:last-child {
                text-align: right;
            }

        .detail-table td {
            padding: 12px 16px;
            font-size: 0.92rem;
            color: #333;
            border-bottom: 1px solid #f8f8f8;
        }

            .detail-table td:last-child {
                text-align: right;
                font-weight: 700;
            }

        .detail-table tr:last-child td {
            border-bottom: none;
        }

        .detail-table tr.status-cancel td {
            opacity: 0.4;
            text-decoration: line-through;
        }

    .status-badge {
        font-size: 0.75rem;
        padding: 2px 8px;
        border-radius: 10px;
        font-weight: 700;
        display: inline-block;
        margin-left: 6px;
    }

    .badge-unserved {
        background: #fff3cd;
        color: #856404;
    }

    .badge-cancel {
        background: #f8d7da;
        color: #842029;
    }

    .amount-section {
        padding: 16px 24px;
        background: #fff;
        border-top: 1px solid #e8e8e8;
    }

    .amount-row {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
        font-size: 0.92rem;
        color: #555;
    }

        .amount-row.discount {
            color: #27ae60;
        }

        .amount-row.total {
            font-size: 1.3rem;
            font-weight: 700;
            color: #1a1a1a;
            border-top: 2px solid #eee;
            margin-top: 8px;
            padding-top: 12px;
        }

            .amount-row.total span:last-child {
                color: #c0392b;
            }

    .cash-section {
        display: none;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid #f0f0f0;
    }

    .cash-label {
        font-size: 0.85rem;
        color: #888;
        margin-bottom: 6px;
    }

    .cash-input-wrap {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .cash-input {
        width: 140px;
        padding: 10px 14px;
        border: 2px solid #ddd;
        border-radius: 10px;
        font-size: 1rem;
        font-family: inherit;
        font-weight: 700;
        outline: none;
        transition: border-color 0.2s;
        text-align: right;
    }

        .cash-input:focus {
            border-color: #c0392b;
        }

    .change-display {
        font-size: 1rem;
        font-weight: 700;
        color: #27ae60;
    }

    .pay-method-btn {
        flex: 1;
        padding: 8px 4px;
        border: 2px solid #ddd;
        border-radius: 8px;
        background: #fff;
        font-family: inherit;
        font-size: 0.82rem;
        font-weight: 500;
        color: #888;
        cursor: pointer;
        transition: all 0.15s;
        text-align: center;
    }

        .pay-method-btn.active {
            border-color: #c0392b;
            background: #fff5f5;
            color: #c0392b;
            font-weight: 700;
        }

    .checkout-btn-wrap {
        margin-top: 14px;
    }

    .btn-checkout {
        width: 100%;
        padding: 16px;
        background: #c0392b;
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        transition: background 0.2s;
        display: none;
    }

        .btn-checkout.show {
            display: block;
        }

        .btn-checkout:hover {
            background: #a93226;
        }

    .empty-right {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #ccc;
    }

        .empty-right .icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty-right p {
            font-size: 0.95rem;
        }
</style>

<div class="layout">

    <!-- ── 左側 ── -->
    <div class="left-panel">
        <div class="left-header">
            <div class="left-title">💳 結帳</div>
            <div class="tab-wrap">
                <button class="tab-btn active" onclick="switchTab('dine')">🪑 內用</button>
                <button class="tab-btn" onclick="switchTab('take')">🥡 外帶</button>
            </div>
        </div>

        <!-- 內用：桌號格子 -->
        <div class="table-grid" id="dineGrid">
            @foreach (var table in Model.Tables)
            {
                if (table.HasOrder)
                {
                    <button class="table-btn has-order @(table.HasUnserved ? "unserved" : "")"
                            id="tbtn-@table.PreOrderId"
                            onclick="loadDetail(@table.PreOrderId, this)">
                        <span class="table-icon">🪑</span>
                        <span class="table-name">@table.TableName</span>
                        <span class="table-amount">$@table.TotalAmount</span>
                    </button>
                }
                else
                {
                    <div class="table-btn @(table.IsOccupied ? "occupied" : "")" data-tableid="@table.TableId" onclick="selectTable(@table.TableId)">
                        <span class="table-icon" style="opacity:@(table.IsOccupied ? "1" : "0.3")">🪑</span>
                        <span class="table-name" style="color:@(table.IsOccupied ? "#e67e22" : "#ccc")">@table.TableName</span>
                        @if (table.IsOccupied)
                        {
                            <span class="table-amount" style="color:#e67e22">點餐中</span>
                        }
                    </div>
                }
            }
        </div>

        <!-- 外帶：清單 -->
        <div class="takeout-list" id="takeList">
            @foreach (var order in takeOrders)
            {
                <div class="takeout-item @(order.HasUnserved ? "unserved" : "")"
                     id="tbtn-@order.PreOrderId"
                     onclick="loadDetail(@order.PreOrderId, this)">
                    <div class="takeout-number">@order.OrderNumber</div>
                    <div class="takeout-meta">@order.OrderAt.ToString("HH:mm")</div>
                    <div class="takeout-amount">NT$ @order.TotalAmount</div>
                </div>
            }
            @if (!takeOrders.Any())
            {
                <div style="text-align:center;color:#ccc;padding:40px 0;font-size:0.9rem">
                    目前沒有外帶訂單
                </div>
            }
        </div>
    </div>

    <!-- ── 右側 ── -->
    <div class="right-panel">

        <div class="empty-right" id="emptyRight">
            <div class="icon">👈</div>
            <p>請選擇訂單</p>
        </div>

        <div id="checkoutContent" style="display:none;flex-direction:column;height:100%;">

            <div class="right-header">
                <div>
                    <div class="right-title" id="rightTitle">-</div>
                    <div class="right-subtitle" id="rightSubtitle">-</div>
                </div>
            </div>

            <div class="unserved-warning" id="unservedWarning">
                <p>⚠️ 有餐點尚未出餐完成，確定要結帳嗎？</p>
                <div class="warning-btns">
                    <button class="btn-yes" onclick="confirmCancelUnserved()">是，取消未出餐並結帳</button>
                    <button class="btn-no" onclick="closeDetail()">否，關閉</button>
                </div>
            </div>

            <div class="detail-scroll">
                <table class="detail-table">
                    <thead>
                        <tr>
                            <th>餐點名稱</th>
                            <th>結帳份數</th>
                            <th>單價</th>
                            <th>金額</th>
                        </tr>
                    </thead>
                    <tbody id="detailBody"></tbody>
                </table>
            </div>

            <div class="amount-section">
                <div style="margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid #f0f0f0;">
                    <div style="font-size:0.82rem;color:#888;margin-bottom:8px;">付款方式</div>
                    <div style="display:flex;gap:8px;">
                        <button type="button" class="pay-method-btn" id="pmBtn-Cash" onclick="selectPayMethod('Cash')">💵 現金</button>
                        <button type="button" class="pay-method-btn" id="pmBtn-Card" onclick="selectPayMethod('Card')">💳 刷卡</button>
                        <button type="button" class="pay-method-btn" id="pmBtn-Other" onclick="selectPayMethod('Other')">📱 行動支付</button>
                    </div>
                </div>
                <div class="amount-row">
                    <span>總計</span>
                    <span>NT$ <span id="amtOriginal">-</span></span>
                </div>
                <div class="amount-row discount">
                    <span>折扣</span>
                    <span>− NT$ <span id="amtDiscount">-</span></span>
                </div>
                <div class="amount-row total">
                    <span>應付</span>
                    <span>NT$ <span id="amtTotal">-</span></span>
                </div>

                <div class="cash-section" id="cashSection">
                    <div class="cash-label">實收金額</div>
                    <div class="cash-input-wrap">
                        <input type="number" class="cash-input" id="cashInput"
                               placeholder="0" oninput="calcChange()" />
                        <span style="color:#888;font-size:0.9rem">找零：</span>
                        <span class="change-display" id="changeDisplay">-</span>
                    </div>
                </div>

                <div class="checkout-btn-wrap">
                    <form id="checkoutForm" method="post" action="/Payments/Checkout">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="preOrderId" id="checkoutPreOrderId" value="" />
                        <button type="submit" class="btn-checkout" id="checkoutBtn">
                            結帳 ✓
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div id="toast" style="
            position:fixed; inset:0;
            background:rgba(0,0,0,0.35);
            display:flex; align-items:center; justify-content:center;
            z-index:9999;">
        <div style="
                background:#fff; border-radius:20px;
                padding:40px 60px; text-align:center;
                box-shadow:0 8px 32px rgba(0,0,0,0.2);">
            <div style="font-size:3rem; margin-bottom:12px;">✅</div>
            <div style="font-size:1.4rem; font-weight:700; color:#1a1a1a;">結帳成功！</div>
        </div>
    </div>
    <script>
        setTimeout(() => {
            const t = document.getElementById('toast');
            t.style.transition = 'opacity 0.4s';
            t.style.opacity = '0';
            setTimeout(() => t.remove(), 300);
        }, 2000);
    </script>
}

<script>
    let currentPreOrderId = null;
    let currentPayMethod  = null;
    let currentTotal      = 0;

    function switchTab(tab) {
        const isDine = tab === 'dine';
        document.querySelectorAll('.tab-btn').forEach((b, i) =>
            b.classList.toggle('active', isDine ? i === 0 : i === 1));
        document.getElementById('dineGrid').style.display = isDine ? 'grid' : 'none';
        document.getElementById('takeList').style.display = isDine ? 'none' : 'block';
    }

    async function loadDetail(preOrderId, el) {
        document.querySelectorAll('.table-btn, .takeout-item').forEach(b =>
            b.classList.remove('active-selected'));
        el.classList.add('active-selected');
        currentPreOrderId = preOrderId;

        const res  = await fetch(`/Payments/GetDetail?preOrderId=${preOrderId}`);
        const data = await res.json();
        renderDetail(data);
    }

    function renderDetail(data) {
        document.getElementById('emptyRight').style.display      = 'none';
        document.getElementById('checkoutContent').style.display = 'flex';

        document.getElementById('rightTitle').textContent =
            data.inOrOut ? `🪑 ${data.tableName}` : `🥡 外帶`;
        document.getElementById('rightSubtitle').textContent = data.orderNumber;

        const tbody = document.getElementById('detailBody');
        tbody.innerHTML = '';
        data.items.forEach(item => {
            const isCancelled = item.status === 2;
            const isUnserved  = item.status === 0;
            const tr = document.createElement('tr');
            if (isCancelled) tr.classList.add('status-cancel');

            let badge = '';
            if (isUnserved)  badge = `<span class="status-badge badge-unserved">未出餐</span>`;
            if (isCancelled) badge = `<span class="status-badge badge-cancel">已取消</span>`;

            tr.innerHTML = `
                <td>${item.productName}${badge}</td>
                <td>${isCancelled ? '-' : item.qty}</td>
                <td>NT$ ${item.unitPrice}</td>
                <td>${isCancelled ? '-' : 'NT$ ' + item.subTotal}</td>
            `;
            tbody.appendChild(tr);
        });

        document.getElementById('amtOriginal').textContent = data.originalAmount;
        document.getElementById('amtDiscount').textContent = data.discountAmount;
        document.getElementById('amtTotal').textContent    = data.totalAmount;
        currentTotal     = data.totalAmount;
        currentPayMethod = data.payMethod;

        selectPayMethod(data.payMethod);
        document.getElementById('cashInput').value = '';
        document.getElementById('changeDisplay').textContent = '-';

        const warning = document.getElementById('unservedWarning');
        const btn     = document.getElementById('checkoutBtn');
        if (data.hasUnserved) {
            warning.style.display = 'block';
            btn.classList.remove('show');
        } else {
            warning.style.display = 'none';
            btn.classList.add('show');
        }

        document.getElementById('checkoutPreOrderId').value = data.preOrderId;
    }

    async function confirmCancelUnserved() {
        const res = await fetch('/Payments/CancelUnserved', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: `preOrderId=${currentPreOrderId}`
        });
        const data = await res.json();
        renderDetail(data);
    }

    function closeDetail() {
        document.getElementById('checkoutContent').style.display = 'none';
        document.getElementById('emptyRight').style.display      = 'flex';
        document.querySelectorAll('.table-btn, .takeout-item').forEach(b =>
            b.classList.remove('active-selected'));
        currentPreOrderId = null;
    }

    function selectPayMethod(method) {
        currentPayMethod = method;
        ['Cash', 'Card', 'Other'].forEach(m => {
            const btn = document.getElementById('pmBtn-' + m);
            if (btn) btn.classList.toggle('active', m === method);
        });
        document.getElementById('cashSection').style.display = method === 'Cash' ? 'block' : 'none';
        // 把選擇的付款方式帶入 form
        let input = document.getElementById('checkoutPayMethod');
        if (!input) {
            input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'payMethod';
            input.id   = 'checkoutPayMethod';
            document.getElementById('checkoutForm').appendChild(input);
        }
        input.value = method;
    }

    function calcChange() {
        const paid   = parseInt(document.getElementById('cashInput').value || 0);
        const change = paid - currentTotal;
        document.getElementById('changeDisplay').textContent =
            paid >= currentTotal ? `NT$ ${change}` : '金額不足';
    }

    document.addEventListener('DOMContentLoaded', () => {
        const defaultTableId = @(ViewBag.DefaultTableId ?? 0);

            if (defaultTableId > 0) {
        const tables = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model.Tables.Select(t => new { t.TableId, t.PreOrderId, t.HasOrder })
                ));
        const target = tables.find(t => t.tableId === defaultTableId);
        if (target) {
            if (target.hasOrder && target.preOrderId) {
                // 有訂單 → 直接載入明細
                const el = document.getElementById('tbtn-' + target.preOrderId);
                if (el) {
                    el.classList.add('active-selected');
                    loadDetail(target.preOrderId, el);
                }
            }
            // 不管有沒有訂單，捲動到該桌位
            const anyEl = document.getElementById('tbtn-' + target.preOrderId)
                       || document.querySelector(`[data-tableid="${defaultTableId}"]`);
            if (anyEl) anyEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    } else {
        switchTab('take');
    }
    });
</script>
