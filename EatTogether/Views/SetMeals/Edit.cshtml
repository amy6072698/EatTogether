@model EatTogether.Models.ViewModels.SetMealViewModel
@{
    ViewData["Title"] = "編輯套餐";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">編輯套餐</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">套餐管理</a></li>
        <li class="breadcrumb-item active">編輯套餐</li>
    </ol>

    <!-- 套餐基本資料 -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-edit me-1"></i>套餐基本資料
        </div>
        <div class="card-body">

            <form method="post" enctype="multipart/form-data" asp-action="Edit" asp-route-id="@Model.Id">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />
                <input type="hidden" id="croppedImageData" name="CroppedImageData" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">套餐名稱 <span class="text-danger">*</span></label>
                        <input asp-for="SetMealName" class="form-control" />
                        <span asp-validation-for="SetMealName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">套餐定價</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="SetPrice" class="form-control" min="0" />
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">折扣類型 <span class="text-danger">*</span></label>
                        <select asp-for="DiscountType" asp-items="Model.DiscountTypeOptions"
                                class="form-select" onchange="updateDiscountLabel()"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label" id="discountLabel">
                            @(Model.DiscountType == "percent" ? "折扣值（%）" : "折扣值（元）")
                            <span class="text-danger">*</span>
                        </label>
                        <input asp-for="DiscountValue" class="form-control" min="0" />
                        <span asp-validation-for="DiscountValue" class="text-danger small"></span>
                    </div>

                    <!-- 圖片上傳 -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label">圖片上傳</label>
                        <input type="file" id="imageInput" class="form-control" accept="image/*"
                               onchange="openCropper(this)" />
                        <div id="previewBox" class="mt-2"
                             style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none" : "")">
                            <img id="previewImg" src="@(Model.ImageUrl ?? "")"
                                 style="width:100%; max-height:200px; object-fit:cover; border-radius:8px;" />
                            <button type="button" class="btn btn-sm btn-outline-secondary mt-1"
                                    onclick="openCropperAgain()">
                                <i class="fas fa-crop me-1"></i>重新裁切
                            </button>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">描述</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">其他設定</label>
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label class="form-check-label" asp-for="IsActive">啟用</label>
                        </div>
                    </div>
                </div>

                <div class="mb-3 text-muted small">
                    建立時間：@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                    @if (Model.UpdatedAt.HasValue)
                    {
                        <span class="ms-3">最後更新：@Model.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</span>
                    }
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>儲存基本資料
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>返回列表
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- 套餐餐點明細 -->
    <div class="card mb-4">
        <div class="card-header">
            <i class="fas fa-list me-1"></i>套餐包含餐點
        </div>
        <div class="card-body">
            <div id="itemAlertBox"></div>

            <table class="table table-bordered table-hover mb-4">
                <thead>
                    <tr>
                        <th>餐點名稱</th>
                        <th>單價</th>
                        <th>數量</th>
                        <th>是否選擇性</th>
                        <th>群組編號</th>
                        <th>選取上限</th>
                        <th>顯示順序</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr id="item-@item.Id">
                            <td>@item.DishName</td>
                            <td>$@item.DishPrice</td>
                            <td>@item.Quantity</td>
                            <td>
                                @if (item.IsOptional)
                                {
                                    <span class="badge bg-warning text-dark">選擇性</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">固定</span>
                                }
                            </td>
                            <td>@(item.OptionGroupNo?.ToString() ?? "—")</td>
                            <td>@(item.PickLimit?.ToString() ?? "—")</td>
                            <td>@item.DisplayOrder</td>
                            <td>
                                <button class="btn btn-danger btn-sm" onclick="removeItem(@item.Id)">
                                    <i class="fas fa-trash"></i> 移除
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <h6 class="fw-bold">新增餐點到套餐</h6>
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">選擇餐點</label>
                    <select id="newDishId" class="form-select">
                        <option value="">請選擇餐點</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label">數量</label>
                    <input type="number" id="newQuantity" class="form-control" value="1" min="1" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">類型</label>
                    <select id="newIsOptional" class="form-select" onchange="toggleOptionalFields()">
                        <option value="false">固定包含</option>
                        <option value="true">選擇性</option>
                    </select>
                </div>
                <div class="col-md-1" id="groupNoField" style="display:none">
                    <label class="form-label">群組</label>
                    <input type="number" id="newOptionGroupNo" class="form-control" value="1" min="1" />
                </div>
                <div class="col-md-1" id="pickLimitField" style="display:none">
                    <label class="form-label">上限</label>
                    <input type="number" id="newPickLimit" class="form-control" value="1" min="1" />
                </div>
                <div class="col-md-1">
                    <label class="form-label">順序</label>
                    <input type="number" id="newDisplayOrder" class="form-control" value="1" min="1" />
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-success w-100" onclick="addItem()">
                        <i class="fas fa-plus me-1"></i>新增
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Cropper Modal -->
<div class="modal fade" id="cropperModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">裁切圖片</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div style="max-height:500px; overflow:hidden;">
                    <img id="cropperImage" src="" style="max-width:100%;" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" onclick="confirmCrop()">
                    <i class="fas fa-check me-1"></i>確認裁切
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <script>
        const setMealId = @Model.Id;
        let cropper = null;
        let originalFile = null;

        function updateDiscountLabel() {
            const type = document.getElementById("DiscountType").value;
            document.getElementById("discountLabel").innerHTML =
                type === "percent"
                    ? '折扣值（%） <span class="text-danger">*</span>'
                    : '折扣值（元） <span class="text-danger">*</span>';
        }

        function openCropper(input) {
            if (!input.files || !input.files[0]) return;
            originalFile = input.files[0];

            const reader = new FileReader();
            reader.onload = e => {
                const img = document.getElementById("cropperImage");
                img.src = e.target.result;

                const modal = new bootstrap.Modal(document.getElementById("cropperModal"));
                modal.show();

                document.getElementById("cropperModal").addEventListener("shown.bs.modal", () => {
                    if (cropper) cropper.destroy();
                    cropper = new Cropper(img, {
                        aspectRatio: 4 / 3,
                        viewMode: 1,
                        movable: true,
                        zoomable: true,
                        rotatable: false
                    });
                }, { once: true });
            };
            reader.readAsDataURL(originalFile);
        }

        function openCropperAgain() {
            if (!originalFile) return;
            openCropper(document.getElementById("imageInput"));
        }

        function confirmCrop() {
            if (!cropper) return;

            const canvas = cropper.getCroppedCanvas({ width: 800, height: 600 });
            const base64  = canvas.toDataURL("image/jpeg", 0.9);

            document.getElementById("croppedImageData").value = base64;
            document.getElementById("previewImg").src = base64;
            document.getElementById("previewBox").style.display = "";

            bootstrap.Modal.getInstance(document.getElementById("cropperModal")).hide();
            cropper.destroy();
            cropper = null;
        }

        function toggleOptionalFields() {
            const isOptional = document.getElementById("newIsOptional").value === "true";
            document.getElementById("groupNoField").style.display   = isOptional ? "" : "none";
            document.getElementById("pickLimitField").style.display = isOptional ? "" : "none";
        }

        async function addItem() {
            const dishId     = document.getElementById("newDishId").value;
            const isOptional = document.getElementById("newIsOptional").value === "true";

            if (!dishId) {
                showAlert("itemAlertBox", "warning", "請選擇餐點");
                return;
            }

            const data = {
                SetMealId:     setMealId,
                DishId:        parseInt(dishId),
                Quantity:      parseInt(document.getElementById("newQuantity").value),
                IsOptional:    isOptional,
                OptionGroupNo: isOptional ? parseInt(document.getElementById("newOptionGroupNo").value) : null,
                PickLimit:     isOptional ? parseInt(document.getElementById("newPickLimit").value) : null,
                DisplayOrder:  parseInt(document.getElementById("newDisplayOrder").value)
            };

            const res = await fetch("/SetMeals/AddItem", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                showAlert("itemAlertBox", "success", "新增成功");
                setTimeout(() => location.reload(), 1000);
            } else {
                const err = await res.json();
                showAlert("itemAlertBox", "danger", err.message || "新增失敗");
            }
        }

        async function removeItem(itemId) {
            if (!confirm("確定要移除此餐點嗎？")) return;

            const res = await fetch(`/SetMeals/RemoveItem/${itemId}`, { method: "POST" });

            if (res.ok) {
                document.getElementById(`item-${itemId}`)?.remove();
                showAlert("itemAlertBox", "success", "移除成功");
            } else {
                showAlert("itemAlertBox", "danger", "移除失敗");
            }
        }

        function showAlert(boxId, type, message) {
            document.getElementById(boxId).innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;
        }

        // 載入餐點下拉選單
        async function loadDishOptions() {
            const res = await fetch("/Dishes/GetAllJson");
            if (!res.ok) return;
            const dishes = await res.json();
            const select = document.getElementById("newDishId");
            dishes.forEach(d => {
                const option = document.createElement("option");
                option.value = d.id;
                option.text  = `${d.dishName}（$${d.price}）`;
                select.appendChild(option);
            });
        }

        loadDishOptions();
    </script>
}
