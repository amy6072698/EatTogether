@model IEnumerable<EatTogether.Models.ViewModels.SetMealViewModel>
@{
    ViewData["Title"] = "套餐管理";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">套餐管理</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">首頁</a></li>
        <li class="breadcrumb-item active">套餐管理</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div><i class="fas fa-box-open me-1"></i>套餐列表</div>
            <div class="d-flex gap-2 align-items-center">
                <input type="text" id="searchInput" class="form-control form-control-sm"
                       placeholder="搜尋套餐..." style="width:180px" oninput="filterCards()" />
                <a asp-action="Create" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus me-1"></i>新增套餐
                </a>
            </div>
        </div>
        <div class="card-body">
            <div id="alertBox"></div>

            <div class="row g-3" id="setMealCardContainer">
                @foreach (var item in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3 setmeal-card"
                         data-name="@item.SetMealName.ToLower()"
                         data-order="@item.DisplayOrder">
                        <div class="card h-100 shadow-sm">
                            <div style="position:relative; padding-top:75%; overflow:hidden; background:#f8f9fa;">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl"
                                         style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover;"
                                         alt="@item.SetMealName"
                                         onerror="this.src='/images/no-image.png'" />
                                }
                                else
                                {
                                    <div style="position:absolute; top:0; left:0; width:100%; height:100%; display:flex; align-items:center; justify-content:center;" class="text-muted">
                                        <i class="fas fa-image fa-3x"></i>
                                    </div>
                                }
                            </div>

                            <div class="card-body p-2">
                                <h6 class="card-title mb-1 fw-bold text-truncate" title="@item.SetMealName">
                                    @item.SetMealName
                                </h6>

                                <div class="fw-bold text-danger mb-1">
                                    @(item.SetPrice.HasValue ? $"${item.SetPrice}" : "未設定定價")
                                </div>

                                <div class="text-muted small mb-1">
                                    @if (item.DiscountType == "percent")
                                    {
                                        <span>折扣：@item.DiscountValue%</span>
                                    }
                                    else
                                    {
                                        <span>折扣：$@item.DiscountValue</span>
                                    }
                                </div>

                                <div class="text-muted small mb-1">
                                    @if (item.StartDate.HasValue || item.EndDate.HasValue)
                                    {
                                        <i class="fas fa-calendar-alt me-1 text-primary"></i>
                                        <span class="text-primary fw-bold">
                                            @(item.StartDate?.ToString("yyyy/MM/dd") ?? "—") ~ 
                                            @(item.EndDate?.ToString("yyyy/MM/dd") ?? "—")
                                        </span>
                                    }
                                    else
                                    {
                                        <i class="fas fa-calendar-check me-1"></i>
                                        <span>不限日期</span>
                                    }
                                </div>

                                <div class="text-muted small mb-2">
                                    <i class="fas fa-list me-1"></i>包含 @item.Items.Count 道餐點
                                </div>

                                <div class="d-flex flex-wrap gap-1 mb-2">
                                    @if (item.IsActive)
                                    {
                                        var today = DateOnly.FromDateTime(DateTime.Today);
                                        if (item.StartDate.HasValue && today < item.StartDate.Value)
                                        {
                                            <span class="badge bg-info text-dark">尚未開始</span>
                                        }
                                        else if (item.EndDate.HasValue && today > item.EndDate.Value)
                                        {
                                            <span class="badge bg-danger">已過期</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">進行中</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">停用</span>
                                    }
                                    @if (item.DiscountType == "percent")
                                    {
                                        <span class="badge bg-light text-dark border">百分比</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">固定折扣</span>
                                    }
                                </div>

                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm flex-fill">
                                        <i class="fas fa-edit"></i> 編輯
                                    </a>
                                    <button class="btn btn-danger btn-sm flex-fill"
                                            onclick="disableSetMeal(@item.Id)">
                                        <i class="fas fa-trash"></i> 停用
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="fas fa-box-open fa-3x mb-3"></i>
                    <p>目前沒有套餐資料</p>
                </div>
            }

            <!-- 分頁 -->
            <div class="d-flex justify-content-between align-items-center mt-4">
                <div class="text-muted small" id="pageInfo"></div>
                <nav>
                    <ul class="pagination pagination-sm mb-0" id="pagination"></ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const PAGE_SIZE = 12;
        let currentPage = 1;
        let filteredCards = [];

        function filterCards() {
            const search = document.getElementById("searchInput").value.toLowerCase();

            filteredCards = Array.from(document.querySelectorAll(".setmeal-card")).filter(card => {
                return !search || card.dataset.name.includes(search);
            });

            // 依順序排序
            filteredCards.sort((a, b) => parseInt(a.dataset.order) - parseInt(b.dataset.order));

            currentPage = 1;
            renderPage();
        }

        function renderPage() {
            const allCards = Array.from(document.querySelectorAll(".setmeal-card"));

            allCards.forEach(c => c.style.display = "none");

            const start = (currentPage - 1) * PAGE_SIZE;
            const end   = start + PAGE_SIZE;
            filteredCards.slice(start, end).forEach(c => c.style.display = "");

            const total      = filteredCards.length;
            const totalPages = Math.ceil(total / PAGE_SIZE) || 1;
            document.getElementById("pageInfo").textContent =
                `顯示第 ${Math.min(start + 1, total)} 至 ${Math.min(end, total)} 筆，共 ${total} 筆記錄`;

            const pagination = document.getElementById("pagination");
            pagination.innerHTML = "";

            for (let i = 1; i <= totalPages; i++) {
                const li = document.createElement("li");
                li.className = `page-item ${i === currentPage ? "active" : ""}`;
                li.innerHTML = `<button class="page-link" onclick="goToPage(${i})">${i}</button>`;
                pagination.appendChild(li);
            }
        }

        function goToPage(page) {
            currentPage = page;
            renderPage();
        }

        async function disableSetMeal(id) {
            if (!confirm("確定要停用此套餐嗎？")) return;

            const res = await fetch(`/SetMeals/Disable/${id}`, { method: "POST" });

            if (res.ok) {
                showAlert("success", "停用成功");
                setTimeout(() => location.reload(), 1000);
            } else {
                showAlert("danger", "停用失敗，請稍後再試");
            }
        }

        function showAlert(type, message) {
            document.getElementById("alertBox").innerHTML = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;
        }

        // 初始化
        filteredCards = Array.from(document.querySelectorAll(".setmeal-card"));
        renderPage();
    </script>
}