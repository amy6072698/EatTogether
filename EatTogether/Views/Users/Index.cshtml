                    <!-- /Demo 資料 -->
                </tbody>
            </table>
        </div>
    </div>

</div>


<!-- ============================================================
     新增員工 Modal
     ============================================================ -->
<div class="modal fade" id="modal-create-user" tabindex="-1" aria-labelledby="modal-create-user-label" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modal-create-user-label">
                    <i class="fa-solid fa-user-plus me-2 text-primary"></i>新增員工
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body user-index">
                <form id="form-create-user" novalidate autocomplete="off">

                    <div class="modal-section-heading">基本資料</div>

                    <div class="row g-3">

                        <!-- 第一行：員工編號 + 姓名 + 啟用狀態 -->
                        <div class="col-md-4">
                            <label class="form-label" for="create-user-number">員工編號</label>
                            <input type="text" class="form-control" id="create-user-number"
                                   readonly placeholder="系統自動產生"
                                   style="background-color:#f8f9fa; color:#6c757d;" />
                            <div class="field-hint">系統自動產生，不可修改</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="create-name">
                                姓名 <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" id="create-name"
                                   placeholder="請輸入姓名" maxlength="50" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="create-status">
                                啟用狀態 <span class="text-danger">*</span>
                            </label>
                            <select class="form-select" id="create-status">
                                <option value="1">在職（啟用）</option>
                                <option value="0">請假（暫停登入）</option>
                            </select>
                        </div>

                        <!-- 帳號 -->
                        <div class="col-md-6">
                            <label class="form-label" for="create-account">
                                帳號 <span class="text-danger">*</span>
                            </label>
                            <div class="input-with-check">
                                <input type="text" class="form-control" id="create-account"
                                       placeholder="請輸入帳號" maxlength="50" autocomplete="off" />
                                <label class="same-empno-check">
                                    <input type="checkbox" id="create-account-same-empno" />
                                    同員工編號
                                </label>
                            </div>
                        </div>

                        <!-- 密碼 -->
                        <div class="col-md-6">
                            <label class="form-label" for="create-password">
                                密碼 <span class="text-danger">*</span>
                            </label>
                            <div class="input-with-check">
                                <div class="position-relative flex-grow-1">
                                    <input type="password" class="form-control pe-5" id="create-password"
                                           placeholder="至少 6 碼，含英文與數字" maxlength="100" autocomplete="new-password" />
                                    <button type="button" class="toggle-password btn btn-link position-absolute end-0 top-50 translate-middle-y pe-2"
                                            data-target="create-password" style="color:#6c757d;">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>
                                </div>
                                <label class="same-empno-check">
                                    <input type="checkbox" id="create-password-same-empno" />
                                    同員工編號
                                </label>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="col-md-6">
                            <label class="form-label" for="create-email">Email</label>
                            <input type="email" class="form-control" id="create-email"
                                   placeholder="example@email.com" maxlength="100" />
                        </div>

                        <!-- 手機 -->
                        <div class="col-md-6">
                            <label class="form-label" for="create-phone">手機</label>
                            <input type="text" class="form-control" id="create-phone"
                                   placeholder="0912345678" maxlength="10" />
                        </div>

                        <!-- 到職日期 -->
                        <div class="col-md-6">
                            <label class="form-label" for="create-hire-date">到職日期</label>
                            <input type="text" class="form-control" id="create-hire-date"
                                   placeholder="YYYY-MM-DD" />
                        </div>
                    </div>


                    <!-- 角色 -->
                    <div class="modal-section-heading">
                        角色（可多選）<span class="text-danger ms-1">*</span>
                    </div>
                    <p class="field-hint mb-2">角色決定員工可存取的後台功能</p>

                    <div class="role-checkbox-grid">
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="1" /><span>店長</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="2" /><span>副店長</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="3" /><span>收銀員</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="4" /><span>外場服務生</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="5" /><span>內場廚師</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="6" /><span>工讀生</span>
                        </label>
                    </div>

                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="btn-create-user">新增</button>
            </div>
        </div>
    </div>
</div>


<!-- ============================================================
     編輯員工 Modal
     ============================================================ -->
<div class="modal fade" id="modal-edit-user" tabindex="-1" aria-labelledby="modal-edit-user-label" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modal-edit-user-label">
                    <i class="fa-solid fa-user-pen me-2 text-primary"></i>編輯員工資訊
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="關閉"></button>
            </div>

            <div class="modal-body user-index">
                <form id="form-edit-user" novalidate autocomplete="off">
                    <input type="hidden" id="edit-user-id" />

                    <div class="modal-section-heading">基本資料</div>

                    <div class="row g-3">

                        <!-- 第一行：員工編號 + 姓名 + 啟用狀態 -->
                        <div class="col-md-4">
                            <label class="form-label" for="edit-user-number">員工編號</label>
                            <input type="text" class="form-control" id="edit-user-number"
                                   readonly style="background-color:#f8f9fa; color:#6c757d;" />
                            <div class="field-hint">系統自動產生，不可修改</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="edit-name">
                                姓名 <span class="text-danger">*</span>
                            </label>
                            <input type="text" class="form-control" id="edit-name"
                                   placeholder="請輸入姓名" maxlength="50" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="edit-status">啟用狀態</label>
                            <select class="form-select" id="edit-status">
                                <option value="1">在職（啟用）</option>
                                <option value="0">請假（暫停登入）</option>
                            </select>
                        </div>

                        <!-- 帳號（可修改 + 同員工編號） -->
                        <div class="col-md-6">
                            <label class="form-label" for="edit-account">帳號</label>
                            <div class="input-with-check">
                                <input type="text" class="form-control" id="edit-account"
                                       placeholder="請輸入帳號" maxlength="50" autocomplete="off" />
                                <label class="same-empno-check">
                                    <input type="checkbox" id="edit-account-same-empno" />
                                    同員工編號
                                </label>
                            </div>
                        </div>

                        <!-- 密碼（選填） -->
                        <div class="col-md-6">
                            <label class="form-label" for="edit-password">密碼</label>
                            <div class="input-with-check">
                                <div class="position-relative flex-grow-1">
                                    <input type="password" class="form-control pe-5" id="edit-password"
                                           placeholder="留空表示不修改" maxlength="100" autocomplete="new-password" />
                                    <button type="button" class="toggle-password btn btn-link position-absolute end-0 top-50 translate-middle-y pe-2"
                                            data-target="edit-password" style="color:#6c757d;">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>
                                </div>
                                <label class="same-empno-check">
                                    <input type="checkbox" id="edit-password-same-empno" />
                                    同員工編號
                                </label>
                            </div>
                            <div class="field-hint">留空表示不修改，密碼同員工編號登入時將被強制重設密碼</div>
                        </div>

                        <!-- Email -->
                        <div class="col-md-6">
                            <label class="form-label" for="edit-email">Email</label>
                            <input type="email" class="form-control" id="edit-email"
                                   placeholder="example@email.com" maxlength="100" />
                        </div>

                        <!-- 手機 -->
                        <div class="col-md-6">
                            <label class="form-label" for="edit-phone">手機</label>
                            <input type="text" class="form-control" id="edit-phone"
                                   placeholder="0912345678" maxlength="10" />
                        </div>

                        <!-- 到職日期 -->
                        <div class="col-md-6">
                            <label class="form-label" for="edit-hire-date">到職日期</label>
                            <input type="text" class="form-control" id="edit-hire-date"
                                   placeholder="YYYY-MM-DD" />
                        </div>

                        <!-- 建立時間（唯讀） -->
                        <div class="col-md-6">
                            <label class="form-label" for="edit-created-at">建立時間</label>
                            <input type="text" class="form-control" id="edit-created-at"
                                   readonly style="background-color:#f8f9fa; color:#6c757d;" />
                            <div class="field-hint">系統自動產生，不可修改</div>
                        </div>
                    </div>

                    <!-- 角色 -->
                    <div class="modal-section-heading">
                        角色（可多選）<span class="text-danger ms-1">*</span>
                    </div>

                    <div class="role-checkbox-grid">
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="1" /><span>店長</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="2" /><span>副店長</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="3" /><span>收銀員</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="4" /><span>外場服務生</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="5" /><span>內場廚師</span>
                        </label>
                        <label class="role-checkbox-item">
                            <input type="checkbox" class="role-checkbox" value="6" /><span>工讀生</span>
                        </label>
                    </div>

                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary" id="btn-save-user">儲存變更</button>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <link rel="stylesheet" href="~/css/views/user-index.css" />
}

@section Scripts {
    <script src="~/lib/flatpickr/dist/l10n/zh-tw.js"></script>
    <script src="~/js/views/user-index.js"></script>
}
