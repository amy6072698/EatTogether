                                        data-id="1" data-name="陳怡伶" data-emp-no="EMP2025001" title="編輯">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-resign-user"
                                        data-id="1" data-name="陳怡伶" data-emp-no="EMP2025001" title="離職">
                                    <i class="fa-solid fa-user-minus"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <tr data-id="2"
                        data-emp-no="EMP2025002" data-name="林志明"
                        data-is-active="0"       data-account="cashier01"
                        data-email="zhi-ming@eat.com" data-phone="0933456789"
                        data-hire-date="2022-06-15"   data-created-at="2025-01-20 14:30"
                        data-role-ids="3">
                        <td>EMP2025002</td><td>林志明</td><td>cashier01</td>
                        <td>zhi-ming@eat.com</td><td>0933-456-789</td>
                        <td>2022-06-15</td><td>2025-01-20 14:30</td>
                        <td><span class="role-badge">收銀員</span></td>
                        <td><span class="status-badge leave">請假</span></td>
                        <td>
                            <div class="action-btn-group">
                                <button class="btn btn-sm btn-outline-primary btn-edit-user"
                                        data-id="2" data-name="林志明" data-emp-no="EMP2025002" title="編輯">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger btn-resign-user"
                                        data-id="2" data-name="林志明" data-emp-no="EMP2025002" title="離職">
                                    <i class="fa-solid fa-user-minus"></i>
                                </button>
                            </div>
                        </td>
                    </tr>

                    <tr data-id="3"
                        data-emp-no="EMP2024003" data-name="王小明"
                        data-is-active="0"       data-account="parttime01"
                        data-email="xiao-ming@eat.com" data-phone="0988123456"
                        data-hire-date="2023-09-01"    data-created-at="2024-09-01 08:45"
                        data-role-ids="6">
                        <td>EMP2024003</td><td>王小明</td><td>parttime01</td>
                        <td>xiao-ming@eat.com</td><td>0988-123-456</td>
                        <td>2023-09-01</td><td>2024-09-01 08:45</td>
                        <td><span class="role-badge">工讀生</span></td>
                        <td><span class="status-badge resigned">離職</span></td>
                        <td>
                            <div class="action-btn-group">
                                <button class="btn btn-sm btn-outline-primary btn-edit-user"
                                        data-id="3" data-name="王小明" data-emp-no="EMP2024003" title="編輯">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-success btn-reinstate-user"
