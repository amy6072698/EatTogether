@{
    ViewData["Title"] = "員工管理";
}

<div class="container-fluid px-4 user-index">

    <!-- 頁面標題列 -->
    <div class="d-flex align-items-start justify-content-between mt-4 mb-4">
        <div>
            <h1 class="page-header-title">員工管理</h1>
            <p class="page-header-subtitle">管理餐廳員工資訊</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <select id="sort-select" class="form-select form-select-sm" style="width:auto;">
                <option value="HireDateDesc">到職日期（最新）</option>
                <option value="HireDateAsc">到職日期（最舊）</option>
                <option value="CreatedAtDesc">建立時間（最新）</option>
            </select>
            @* TODO: 後端連線後依 Staff_Manage 權限決定是否渲染 *@
            <button id="btn-open-create" class="btn btn-sm btn-primary">
                <i class="fa-solid fa-plus me-1"></i>新增
            </button>
        </div>
    </div>

    <!-- 搜尋列 -->
    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-2 col-sm-6">
                    <div class="search-field">
                        <label class="search-label" for="search-emp-no">員工編號</label>
                        <input type="text" class="form-control form-control-sm" id="search-emp-no" />
                    </div>
                </div>
                <div class="col-md-2 col-sm-6">
                    <div class="search-field">
                        <label class="search-label" for="search-name">姓名</label>
                        <input type="text" class="form-control form-control-sm" id="search-name" />
                    </div>
                </div>
                <div class="col-md-2 col-sm-6">
                    <div class="search-field">
                        <label class="search-label" for="search-account">帳號</label>
                        <input type="text" class="form-control form-control-sm" id="search-account" />
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <div class="search-field">
                        <label class="search-label" for="search-email">Email</label>
                        <input type="text" class="form-control form-control-sm" id="search-email" />
                    </div>
                </div>
                <div class="col-auto">
                    <button id="btn-search" class="btn btn-sm btn-primary">
                        <i class="fa-solid fa-magnifying-glass me-1"></i>查詢
                    </button>
                </div>
                <div class="col-auto d-flex align-items-center pb-1">
                    <div class="form-check mb-0">
                        <input type="checkbox" class="form-check-input" id="search-active-only" />
                        <label class="form-check-label small" for="search-active-only">在職</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 員工資料表格 -->
    <div class="card">
        <div class="card-body">
            <table id="user-table" class="table table-bordered table-hover w-100">
                <thead>
                    <tr>
                        <th>員工編號</th>
                        <th>姓名</th>
                        <th>帳號</th>
                        <th>Email</th>
                        <th>手機</th>
                        <th>到職日期</th>
                        <th>建立時間</th>
                        <th>角色</th>
                        <th>狀態</th>
                        <th class="text-center">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @*
                        TODO（後端連線後）：替換為 @foreach (var user in Model) { ... }
                        - data-created-at 格式為 "yyyy-MM-dd HH:mm"
                        - data-role-ids 為逗號分隔角色 ID
                        - 操作欄依 Staff_Manage 權限決定是否渲染
                    *@

                    <!-- Demo 資料 — 後端連線後移除 -->
                    <tr data-id="1"
                        data-emp-no="EMP2025001" data-name="陳怡伶"
                        data-is-active="1"       data-account="manager01"
                        data-email="yi-ling@eat.com" data-phone="0912345678"
                        data-hire-date="2021-03-01"  data-created-at="2025-01-15 09:00"
                        data-role-ids="1">
                        <td>EMP2025001</td><td>陳怡伶</td><td>manager01</td>
